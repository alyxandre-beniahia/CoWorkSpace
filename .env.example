# ===========================================
# CoWork'Space – Variables d'environnement
# Copier vers .env et adapter les valeurs
# ===========================================

# --- Base de données (PostgreSQL) ---
POSTGRES_USER=cowork
POSTGRES_PASSWORD=cowork_dev
POSTGRES_DB=coworkspace_dev

# --- Backend (NestJS / Prisma) ---
DATABASE_URL=postgresql://cowork:cowork_dev@db:5432/coworkspace_dev
NODE_ENV=development
# Secret pour JWT / sessions (à changer en prod)
JWT_SECRET=change-me-in-production

# --- Emails (Resend) ---
# Clé API : https://resend.com → API Keys. Si absente en dev, les emails sont loggés en console.
RESEND_API_KEY=re_xxxx
# Expéditeur : en dev Resend autorise onboarding@resend.dev ; en prod utiliser un domaine vérifié
RESEND_FROM=CoWork'Space <onboarding@resend.dev>
# URL du frontend pour les liens dans les emails (vérification, reset MDP)
APP_URL=http://localhost:5173

# --- Frontend (appels API depuis le navigateur = URL hôte) ---
VITE_API_URL=http://localhost:3002
